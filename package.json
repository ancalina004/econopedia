    "lint": "biome lint --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "^12.3.0",
    "@astrojs/mdx": "^4.1.0",
    "@astrojs/react": "^4.2.1",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.7.0",
    "@fontsource-variable/jetbrains-mono": "^5.1.2",
    "@fontsource-variable/newsreader": "^5.1.0",
    "@sentry/browser": "^9.47.1",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "astro": "^5.7.10",
    "astro-pagefind": "^1.6.0",
    "dompurify": "^3.3.3",
    "katex": "^0.16.38",
    "lucide-react": "^0.469.0",
    "mathjs": "^14.0.0",
    "motion": "^12.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.0",
    "resend": "^4.1.0",
    "tailwindcss": "^4.2.1",
