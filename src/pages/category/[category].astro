---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import PostCard from '../../components/blog/PostCard.astro';
import CategoryBadge from '../../components/blog/CategoryBadge.astro';
import Breadcrumbs from '../../components/common/Breadcrumbs.astro';
import { CATEGORIES } from '../../lib/constants';
import { getCategoryLabel, getCategoryColor } from '../../lib/utils';
import { getAllPosts } from '../../lib/posts';

const { category } = Astro.params;
const categoryMeta = CATEGORIES[category as keyof typeof CATEGORIES];

if (!categoryMeta) {
  return Astro.redirect('/404');
}

const categoryPosts = await getAllPosts(category);

const label = getCategoryLabel(category!);
const color = getCategoryColor(category!);

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label },
];
---

<BaseLayout
  title={label}
  description={categoryMeta?.description || `Articles about ${label} on Econopedia 101.`}
>
  <Container>
    <div class="py-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div
          class="w-3 h-3 rounded-full flex-shrink-0"
          style={`background-color: ${color};`}
        />
        <CategoryBadge category={category!} size="md" />
      </div>
      <h1 class="text-4xl lg:text-5xl font-semibold text-text-primary mb-3">
        {label}
      </h1>
      {categoryMeta?.description && (
        <p class="text-text-secondary text-lg max-w-2xl">
          {categoryMeta.description}
        </p>
      )}
    </header>

    {categoryPosts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        {categoryPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-text-secondary text-lg mb-2">No articles in this category yet.</p>
        <p class="text-text-muted">Check back soon for new content!</p>
      </div>
    )}
  </Container>
</BaseLayout>
