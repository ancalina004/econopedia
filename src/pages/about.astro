---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Separator from '../components/ui/Separator.astro';
import Breadcrumbs from '../components/common/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { SITE } from '../lib/constants';
import { getEntry } from 'astro:content';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'About' },
];

const tasmin = await getEntry('authors', 'tasmin-angelina-houssein');

const values = [
  {
    title: 'Accessibility',
    description: 'We believe financial literacy should be available to everyone, regardless of background or experience level.',
  },
  {
    title: 'Clarity',
    description: 'Complex topics explained simply. No jargon walls, no gatekeeping — just clear, honest explanations.',
  },
  {
    title: 'Empowerment',
    description: 'We arm readers with the knowledge and tools to make confident financial decisions in their own lives.',
  },
  {
    title: 'Curiosity',
    description: 'We encourage asking questions. Every great understanding starts with a simple "but why?".',
  },
];
---

<BaseLayout title="About Econopedia 101" description="Learn about Econopedia 101, our mission to make economics and finance accessible, and the team behind the platform.">
  <Container>
    <div class="py-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <!-- Mission Section -->
    <section class="py-5 lg:py-6">
      <div class="border-t-2 border-text-primary pt-3 mb-4">
        <p class="text-xs font-bold uppercase tracking-[0.12em] text-text-primary">About</p>
      </div>
      <h1 class="text-4xl lg:text-5xl font-semibold text-text-primary mb-4">
        {SITE.tagline}
      </h1>
      <p class="text-xl text-text-secondary leading-relaxed mb-6">
        Your learning platform, news hub, and revision companion.
      </p>
      <div class="grid lg:grid-cols-[2fr_1px_1fr] gap-y-4 lg:gap-y-0 text-text-secondary text-base leading-relaxed">
        <div class="lg:pr-5">
          <p>
            Econopedia 101 is a learning platform, news hub, and revision companion for students,
            young professionals, and anyone who wants to actually understand how money, markets,
            and the economy work. Whether you are revising for your GCSE or A-Level exams, keeping
            up with the latest market moves, or exploring how real businesses operate — this is
            where it all comes together.
          </p>
        </div>

        <!-- Vertical rule -->
        <div class="hidden lg:block bg-border" aria-hidden="true"></div>

        <div class="border-t lg:border-t-0 border-border pt-4 lg:pt-0 lg:pl-5 space-y-4">
          <p>
            We publish timely news and analysis on economics, finance, and business — written
            to be understood, not to impress. Alongside that, you will find structured revision
            notes mapped to GCSE and A-Level syllabi, deep-dives into business models and
            management theory, and interactive tools to reinforce what you learn.
          </p>
          <p>
            Our mission is simple: make economics and business education accessible, engaging,
            and genuinely useful. Understanding money should not be a privilege — and exam
            revision should not feel like decoding a foreign language.
          </p>
        </div>
      </div>
    </section>

    <Separator />

    <!-- Founder Section -->
    {tasmin && (
      <section class="py-5 lg:py-6">
        <div class="border-t-2 border-text-primary pt-3 mb-4">
          <p class="text-xs font-bold uppercase tracking-[0.12em] text-text-primary">Meet the Founder</p>
        </div>
        <div class="grid lg:grid-cols-[auto_1px_1fr] gap-y-4 lg:gap-y-0">
          <div class="lg:pr-5">
            <div class="w-40 h-40 lg:w-52 lg:h-52 overflow-hidden bg-surface-elevated border border-border">
              <Image
                src={tasmin.data.avatar}
                alt={tasmin.data.name}
                width={208}
                height={208}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Vertical rule -->
          <div class="hidden lg:block bg-border" aria-hidden="true"></div>

          <div class="border-t lg:border-t-0 border-border pt-4 lg:pt-0 lg:pl-5">
            <h2 class="text-2xl lg:text-3xl font-semibold text-text-primary">{tasmin.data.name}</h2>
            <p class="text-xs font-bold uppercase tracking-[0.12em] text-accent mt-1">{tasmin.data.role}</p>
            <p class="text-text-secondary mt-4 leading-relaxed max-w-2xl">
              {tasmin.data.bio}
            </p>
            {tasmin.data.socials && (
              <div class="flex gap-4 mt-6">
                {tasmin.data.socials.twitter && (
                  <a href={tasmin.data.socials.twitter} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="Twitter">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                    </svg>
                  </a>
                )}
                {tasmin.data.socials.linkedin && (
                  <a href={tasmin.data.socials.linkedin} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="LinkedIn">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                    </svg>
                  </a>
                )}
                {tasmin.data.socials.instagram && (
                  <a href={tasmin.data.socials.instagram} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="Instagram">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 0 1 1.772 1.153 4.902 4.902 0 0 1 1.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 0 1-1.153 1.772 4.902 4.902 0 0 1-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 0 1-1.772-1.153 4.902 4.902 0 0 1-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 0 1 1.153-1.772A4.902 4.902 0 0 1 5.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 0 0-.748-1.15 3.098 3.098 0 0 0-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 1 1 0 10.27 5.135 5.135 0 0 1 0-10.27zm0 1.802a3.333 3.333 0 1 0 0 6.666 3.333 3.333 0 0 0 0-6.666zm5.338-3.205a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4z" />
                    </svg>
                  </a>
                )}
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <Separator />

    <!-- Values Section -->
    <section class="pt-5 lg:pt-6 pb-12 lg:pb-16">
      <div class="border-t-2 border-text-primary pt-3 mb-4">
        <p class="text-xs font-bold uppercase tracking-[0.12em] text-text-primary">Our Values</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4">
        {values.map((value, i) => (
          <div class:list={[
            'py-4 sm:py-0',
            // Mobile: border-t between items
            i > 0 && 'border-t sm:border-t-0 border-border',
            // sm: 2x2 grid — right-column items on left, second-row items get top border
            i % 2 === 0 && 'sm:border-r sm:pr-5 lg:border-r-0 lg:pr-0',
            i % 2 === 1 && 'sm:pl-5 lg:pl-0',
            i >= 2 && 'sm:border-t sm:pt-4 lg:border-t-0 lg:pt-0',
            // lg: 4 columns — border-r on items 0–2, pl-5 on items 1–3
            i < 3 && 'lg:border-r lg:border-border lg:pr-5',
            i > 0 && 'lg:pl-5',
          ]}>
            <h3 class="text-lg font-semibold text-text-primary mb-2">{value.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </section>
  </Container>
</BaseLayout>
