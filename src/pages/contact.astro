---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import Input from '../components/ui/Input.astro';
import Button from '../components/ui/Button.astro';
import Breadcrumbs from '../components/common/Breadcrumbs.astro';
import { SITE, SOCIALS } from '../lib/constants';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Contact' },
];
---

<BaseLayout title="Contact Us | Econopedia 101" description="Get in touch with the Econopedia 101 team. We'd love to hear your questions, suggestions, or collaboration ideas.">
  <Container>
    <div class="py-8">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <Section>
      <div class="max-w-3xl">
        <h1 class="text-4xl lg:text-5xl font-semibold text-text-primary mb-4">
          Contact Us
        </h1>
        <p class="text-lg text-text-secondary leading-relaxed mb-10">
          Have a question, suggestion, or just want to say hello? We would love to hear from you.
          Fill out the form below and we will get back to you as soon as possible.
        </p>

        <div class="grid lg:grid-cols-5 gap-12">
          <!-- Contact Form -->
          <div class="lg:col-span-3">
            <form action="#" method="POST" class="space-y-6">
              <div class="grid sm:grid-cols-2 gap-6">
                <Input
                  name="name"
                  label="Name"
                  placeholder="Your name"
                  required
                />
                <Input
                  name="email"
                  type="email"
                  label="Email"
                  placeholder="your@email.com"
                  required
                />
              </div>

              <Input
                name="subject"
                label="Subject"
                placeholder="What is this about?"
                required
              />

              <div class="flex flex-col">
                <label for="message" class="text-sm font-medium text-text-secondary mb-1.5">
                  Message
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  placeholder="Tell us more..."
                  required
                  class="w-full border border-border bg-surface px-4 py-2.5 text-text-primary placeholder:text-text-muted focus:ring-2 focus:ring-accent focus:border-accent focus:outline-none transition-colors resize-y"
                ></textarea>
              </div>

              <Button variant="primary" type="submit">
                Send Message
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="22" y1="2" x2="11" y2="13" />
                  <polygon points="22 2 15 22 11 13 2 9 22 2" />
                </svg>
              </Button>
            </form>
          </div>

          <!-- Contact Info Sidebar -->
          <div class="lg:col-span-2">
            <div class="bg-surface border border-border p-6 space-y-6">
              <div>
                <h3 class="font-semibold text-text-primary mb-2">Email</h3>
                <a href="mailto:hello@econopedia101.com" class="text-accent hover:underline text-sm">
                  hello@econopedia101.com
                </a>
              </div>

              <div>
                <h3 class="font-semibold text-text-primary mb-2">Follow Us</h3>
                <div class="flex gap-4">
                  <a href={SOCIALS.twitter} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="Twitter">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
                    </svg>
                  </a>
                  <a href={SOCIALS.instagram} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="Instagram">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                    </svg>
                  </a>
                  <a href={SOCIALS.linkedin} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="LinkedIn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                      <rect x="2" y="9" width="4" height="12" />
                      <circle cx="4" cy="4" r="2" />
                    </svg>
                  </a>
                </div>
              </div>

              <div>
                <h3 class="font-semibold text-text-primary mb-2">Response Time</h3>
                <p class="text-sm text-text-secondary">
                  We aim to respond within 48 hours. For urgent inquiries, reach out via social media.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Section>
  </Container>
</BaseLayout>
