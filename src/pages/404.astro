---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import { CATEGORIES } from '../lib/constants';

const categories = Object.values(CATEGORIES).map(({ label, slug }) => ({
  label: label === 'Banking & Insurance' ? 'Banking' : label,
  href: `/${slug}`,
}));
---

<BaseLayout title="Page Not Found | Econopedia 101" description="The page you're looking for doesn't exist. Browse our articles or head back to the homepage.">
  <Container>
    <div class="flex flex-col items-center text-center py-24 lg:py-32">

      <!-- Top rule -->
      <div class="w-full max-w-xs border-t border-border"></div>

      <!-- 404 number -->
      <p class="text-[6rem] sm:text-[8rem] lg:text-[10rem] leading-none text-border select-none mt-8 mb-2">
        404
      </p>

      <!-- Rule below number -->
      <div class="w-full max-w-xs border-t border-border mt-4"></div>

      <!-- Heading -->
      <h1 class="text-3xl lg:text-4xl font-semibold text-text-primary mt-8 mb-4">
        Page Not Found
      </h1>

      <!-- Description -->
      <p class="text-text-secondary text-lg max-w-md leading-relaxed mb-8">
        Looks like this page took an early retirement. It might have been moved,
        deleted, or perhaps it never existed.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-wrap justify-center gap-4 mb-12">
        <Button variant="primary" href="/">Back to Home</Button>
        <Button variant="outline" href="/blog">Browse Articles</Button>
      </div>

      <!-- Rule above categories -->
      <div class="w-full max-w-lg border-t border-border"></div>

      <!-- Category links -->
      <nav class="flex flex-wrap justify-center gap-x-2 gap-y-1 py-5 text-sm text-text-secondary" aria-label="Categories">
        {categories.map((cat, i) => (
          <>
            <a
              href={cat.href}
              class:list={[
                'transition-colors',
                cat.href === '/trading' && 'hover:text-cat-trading',
                cat.href === '/economics' && 'hover:text-cat-economics',
                cat.href === '/finance' && 'hover:text-cat-finance',
                cat.href === '/business' && 'hover:text-cat-business',
                cat.href === '/banking' && 'hover:text-cat-banking',
                cat.href === '/education' && 'hover:text-cat-education',
              ]}
            >
              {cat.label}
            </a>
            {i < categories.length - 1 && (
              <span class="text-text-muted select-none" aria-hidden="true">&middot;</span>
            )}
          </>
        ))}
      </nav>

      <!-- Bottom rule -->
      <div class="w-full max-w-lg border-t border-border"></div>

    </div>
  </Container>
</BaseLayout>
