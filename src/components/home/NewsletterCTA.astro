---
import Container from '../ui/Container.astro';
import NewsletterForm from '../common/NewsletterForm';
---

<section class="py-(--spacing-section) border-t border-border">
  <Container>
    <div class="max-w-2xl mx-auto text-center">
      <!-- Decorative accent line -->
      <div class="w-12 h-[2px] bg-accent mx-auto mb-6"></div>

      <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-accent mb-3">Free Resources</p>

      <h2 class="text-3xl lg:text-4xl font-semibold text-text-primary leading-tight">
        Learn finance on your terms.
      </h2>

      <p class="mt-3 text-text-secondary text-base leading-relaxed max-w-lg mx-auto">
        Get free guides, cheat sheets, and study resources straight to your inbox. Built for students, self-learners, and the financially curious.
      </p>

      <!-- Interactive newsletter form -->
      <div class="mt-8 relative">
        <NewsletterForm client:visible />
      </div>

      <p class="mt-3 text-xs text-text-muted">
        No spam, ever. Opt out anytime.
      </p>
    </div>
  </Container>
</section>
