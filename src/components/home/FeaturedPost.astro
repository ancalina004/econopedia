---
import { Image } from 'astro:assets';
import CategoryBadge from '../blog/CategoryBadge.astro';
import { formatDate } from '../../lib/utils';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      cover: ImageMetadata | string;
      coverAlt: string;
      coverIsUrl?: boolean;
      categories: string[];
      publishedAt: Date;
      author: { id: string };
    };
  };
  readingTime?: string;
}

const { post, readingTime } = Astro.props;
const { title, description, cover, coverAlt, coverIsUrl, categories, publishedAt, author } = post.data;

const authorName = author.id.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
---

<a href={`/blog/${post.slug}`} class="group block">
  <!-- Featured image — 2:1 aspect ratio for compact hero -->
  <div class="aspect-[2/1] overflow-hidden mb-3">
    {coverIsUrl ? (
      <Image
        src={cover as string}
        alt={coverAlt}
        width={1200}
        height={600}
        loading="eager"
        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
      />
    ) : (
      <Image
        src={cover as ImageMetadata}
        alt={coverAlt}
        loading="eager"
        widths={[400, 600, 800]}
        sizes="(max-width: 1024px) 100vw, 66vw"
        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
      />
    )}
  </div>

  <!-- Category label -->
  {categories[0] && <CategoryBadge category={categories[0]} />}

  <!-- Headline -->
  <h2 class="text-2xl lg:text-3xl font-semibold leading-tight text-text-primary group-hover:text-accent transition-colors mt-2">
    {title}
  </h2>

  <!-- Excerpt -->
  <p class="mt-2 text-text-secondary text-base leading-relaxed line-clamp-3">
    {description}
  </p>

  <!-- Byline -->
  <div class="mt-2 flex items-center gap-2 text-xs text-text-muted">
    <span class="font-medium text-text-secondary">{authorName}</span>
    <span aria-hidden="true">&middot;</span>
    <time datetime={publishedAt.toISOString()}>
      {formatDate(publishedAt)}
    </time>
    {readingTime && (
      <>
        <span aria-hidden="true">&middot;</span>
        <span>{readingTime}</span>
      </>
    )}
  </div>
</a>
