---
import PostCardCompact from '../blog/PostCardCompact.astro';
import Container from '../ui/Container.astro';

interface Props {
  posts: Array<{
    slug: string;
    data: {
      title: string;
      cover: ImageMetadata | string;
      coverAlt: string;
      coverIsUrl?: boolean;
      categories: string[];
      publishedAt: Date;
    };
  }>;
  title: string;
}

const { posts, title } = Astro.props;
---

{posts.length > 0 && (
  <section class="py-5 lg:py-6 border-t border-border">
    <Container>
      <!-- Economist-style section heading -->
      <div class="border-t-2 border-text-primary pt-3 mb-4 flex items-baseline justify-between">
        <h2 class="text-xs font-bold uppercase tracking-[0.12em] text-text-primary">{title}</h2>
        <a href="/blog" class="text-[10px] text-text-muted hover:text-accent transition-colors">
          View all &rarr;
        </a>
      </div>

      <!-- Flat grid: rows stay aligned across columns -->
      <div class="grid md:grid-cols-2 border-t border-border">
        {posts.map((post, i) => (
          <div class:list={[
            'border-b border-border',
            i % 2 === 0 ? 'md:pr-5 md:border-r md:border-border' : 'md:pl-5',
          ]}>
            <PostCardCompact post={post} />
          </div>
        ))}
      </div>

      <!-- Editorial quote -->
      <div class="mt-10 py-12 border-t border-border">
        <div class="max-w-xl mx-auto flex flex-col items-center text-center">
          <svg class="w-8 h-8 text-accent mb-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C9.591 11.7 11 13.166 11 15c0 1.933-1.567 3.5-3.5 3.5-1.172 0-2.283-.569-2.917-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C19.591 11.7 21 13.166 21 15c0 1.933-1.567 3.5-3.5 3.5-1.172 0-2.283-.569-2.917-1.179z" />
          </svg>
          <blockquote class="text-xl lg:text-2xl text-text-primary leading-relaxed italic">
            No matter where you are, see the global economy differently with Econopedia 101. Lets dooo thissss!!
          </blockquote>
          <cite class="mt-5 not-italic flex flex-col items-center gap-0.5">
            <span class="text-sm font-semibold text-text-primary">Tasmin Angelina Houssein</span>
            <span class="text-xs text-text-muted">Founder &amp; Creator</span>
          </cite>
        </div>
      </div>
    </Container>
  </section>
)}
