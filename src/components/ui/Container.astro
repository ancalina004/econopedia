---
interface Props {
  class?: string;
  wide?: boolean;
}

const { class: className, wide = false } = Astro.props;

const maxWidth = wide ? 'max-w-wide' : 'max-w-content';

const classes = [maxWidth, 'mx-auto px-6 sm:px-10 lg:px-20 xl:px-24', className]
  .filter(Boolean)
  .join(' ');
---

<div class={classes}>
  <slot />
</div>
