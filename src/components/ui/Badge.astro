---
interface Props {
  variant?: 'default' | 'trading' | 'economics' | 'finance' | 'business' | 'banking' | 'education';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;

const variantClasses: Record<string, string> = {
  default: 'bg-accent-light text-accent-dark',
  trading: 'bg-[#EDE9FE] text-[#5B21B6] dark:bg-[#1E1433] dark:text-[#B8A5E8]',
  economics: 'bg-[#DBEAFE] text-[#1E40AF] dark:bg-[#131F38] dark:text-[#7EADE8]',
  finance: 'bg-[#E8E7F0] text-[#19155C] dark:bg-[#1C1A3A] dark:text-[#8B86C9]',
  business: 'bg-[#FFF7ED] text-[#9A3412] dark:bg-[#2A1508] dark:text-[#E89850]',
  banking: 'bg-[#ECFEFF] text-[#155E75] dark:bg-[#0A2830] dark:text-[#4CC4D8]',
  education: 'bg-[#FAE8FF] text-[#86198F] dark:bg-[#280D33] dark:text-[#D88AEB]',
};

const baseClasses = 'text-xs font-medium px-2.5 py-0.5 rounded-full';

const classes = [baseClasses, variantClasses[variant], className]
  .filter(Boolean)
  .join(' ');
---

<span class={classes}>
  <slot />
</span>
