---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

{compact ? (
  <a href="/" class="inline-flex items-baseline gap-0.5 no-underline">
    <span class="text-lg font-semibold tracking-wider uppercase text-text-primary leading-none">
      Econopedia
    </span>
    <span class="text-lg font-semibold tracking-wider uppercase text-accent leading-none">
      101
    </span>
  </a>
) : (
  <a href="/" class="inline-flex flex-col items-center no-underline group">
    <div class="flex items-baseline gap-1">
      <span class="text-2xl md:text-3xl lg:text-4xl font-semibold tracking-wider uppercase text-text-primary leading-none">
        Econopedia
      </span>
      <span class="text-2xl md:text-3xl lg:text-4xl font-semibold tracking-wider uppercase text-accent leading-none">
        101
      </span>
    </div>
    <span class="mt-1.5 text-[11px] uppercase tracking-[0.25em] text-text-muted font-sans leading-none">
      Where Money, Business & Economics Connect
    </span>
  </a>
)}
