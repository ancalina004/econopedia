---
import { SITE, FOOTER_LINKS, SOCIALS } from '../../lib/constants';
import Container from '../ui/Container.astro';
---

<footer class="footer-dark" style={`background-color: var(--footer-bg); color: var(--footer-text);`}>
  <!-- Green accent bar -->
  <div style="height: 3px; background-color: var(--footer-accent);"></div>

  <!-- Main footer content -->
  <Container>
    <div class="py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-0">

        <!-- Brand column — 5/12 -->
        <div class="lg:col-span-5 lg:pr-10 lg:border-r" style={`border-color: var(--footer-border);`}>
          <a href="/" class="inline-block no-underline mb-3">
            <span class="text-2xl md:text-3xl uppercase tracking-wider font-semibold whitespace-nowrap" style={`color: var(--footer-text);`}>Econopedia <span style={`color: var(--footer-accent);`}>101</span></span>
          </a>
          <p class="text-sm leading-relaxed max-w-xs" style={`color: var(--footer-text-muted);`}>
            {SITE.tagline}
          </p>
        </div>

        <!-- Link columns — 7/12 -->
        <div class="lg:col-span-7 grid grid-cols-2 sm:grid-cols-4 gap-8 sm:gap-0">

          <!-- Explore -->
          <div class="sm:pl-6" style={`border-color: var(--footer-border);`}>
            <h3 class="footer-heading">Explore</h3>
            <ul class="space-y-2.5">
              {FOOTER_LINKS.explore.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Categories -->
          <div class="sm:pl-6 sm:border-l" style={`border-color: var(--footer-border);`}>
            <h3 class="footer-heading">Categories</h3>
            <ul class="space-y-2.5">
              {FOOTER_LINKS.categories.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Tools -->
          <div class="sm:pl-6 sm:border-l" style={`border-color: var(--footer-border);`}>
            <h3 class="footer-heading">Tools</h3>
            <ul class="space-y-2.5">
              {FOOTER_LINKS.tools.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Legal -->
          <div class="sm:pl-6 sm:border-l" style={`border-color: var(--footer-border);`}>
            <h3 class="footer-heading">Legal</h3>
            <ul class="space-y-2.5">
              {FOOTER_LINKS.legal.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </div>
  </Container>

  <!-- Bottom bar -->
  <div style={`border-top: 1px solid var(--footer-border);`}>
    <Container>
      <div class="flex flex-col sm:flex-row items-center justify-between py-6 gap-4">
        <p class="text-xs" style={`color: var(--footer-text-muted);`}>
          &copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.
        </p>

        <!-- Social icons -->
        <div class="flex items-center gap-4">
          <!-- Twitter / X -->
          <a
            href={SOCIALS.twitter}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon"
            aria-label="Follow us on Twitter"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>

          <!-- Instagram -->
          <a
            href={SOCIALS.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon"
            aria-label="Follow us on Instagram"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <circle cx="12" cy="12" r="5"></circle>
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"></circle>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a
            href={SOCIALS.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon"
            aria-label="Follow us on LinkedIn"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </Container>
  </div>
</footer>

<style>
  .footer-heading {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--footer-text-muted);
    margin-bottom: 1rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--footer-text-secondary);
    transition: color 0.15s ease;
    text-decoration: none;
  }

  .footer-link:hover {
    color: var(--footer-text);
  }

  .social-icon {
    color: var(--footer-text-muted);
    transition: color 0.15s ease;
  }

  .social-icon:hover {
    color: var(--footer-accent-hover);
  }
</style>
