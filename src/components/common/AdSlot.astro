---
interface Props {
  format: 'leaderboard' | 'rectangle' | 'sidebar' | 'in-article';
  id: string;
  class?: string;
}

const { format, id, class: className } = Astro.props;
const pubId = import.meta.env.PUBLIC_ADSENSE_PUB_ID;

// Map format to recommended AdSense responsive styles
const formatStyles: Record<string, string> = {
  leaderboard: 'display:block',
  rectangle: 'display:block',
  sidebar: 'display:block',
  'in-article': 'display:block; text-align:center',
};

const formatMap: Record<string, string> = {
  leaderboard: 'auto',
  rectangle: 'auto',
  sidebar: 'auto',
  'in-article': 'fluid',
};

const layoutMap: Record<string, string | undefined> = {
  'in-article': 'in-article-ad',
};

const style = formatStyles[format] || 'display:block';
const adFormat = formatMap[format] || 'auto';
const adLayout = layoutMap[format];
---

{pubId && (
  <div
    id={`ad-${id}`}
    class:list={['ad-slot', `ad-${format}`, className]}
    aria-hidden="true"
  >
    <ins
      class="adsbygoogle"
      style={style}
      data-ad-client={pubId}
      data-ad-slot={id}
      data-ad-format={adFormat}
      data-full-width-responsive="true"
      {...(adLayout ? { 'data-ad-layout': adLayout } : {})}
    />
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}
