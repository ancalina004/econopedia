---
import { Image } from 'astro:assets';
import CategoryBadge from './CategoryBadge.astro';
import { formatDate } from '../../lib/utils';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      cover: ImageMetadata | string;
      coverAlt: string;
      coverIsUrl?: boolean;
      categories: string[];
      publishedAt: Date;
      author: { id: string };
    };
  };
  readingTime?: string;
  label?: string;
}

const { post, readingTime, label = 'Featured' } = Astro.props;
const { title, description, cover, coverAlt, coverIsUrl, categories, publishedAt, author } = post.data;
---

<a
  href={`/blog/${post.slug}`}
  class="group block border-b border-border pb-8"
>
  <div class="grid md:grid-cols-2 gap-6 md:gap-8">
    <!-- Image: full-bleed, no rounded corners, subtle opacity on hover -->
    <div class="aspect-[3/2] md:aspect-auto overflow-hidden">
      {coverIsUrl ? (
        <Image
          src={cover as string}
          alt={coverAlt}
          width={1200}
          height={800}
          loading="eager"
          class="w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-300"
        />
      ) : (
        <Image
          src={cover as ImageMetadata}
          alt={coverAlt}
          loading="eager"
          widths={[600, 900, 1200]}
          sizes="(max-width: 768px) 100vw, 50vw"
          class="w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-300"
        />
      )}
    </div>

    <!-- Content: large serif headline drives hierarchy -->
    <div class="flex flex-col justify-center gap-3 md:gap-4">
      <div class="flex items-center gap-3">
        <span class="text-xs font-semibold uppercase tracking-widest text-accent">{label}</span>
        {categories[0] && (
          <>
            <span class="text-border" aria-hidden="true">&middot;</span>
            <CategoryBadge category={categories[0]} size="sm" />
          </>
        )}
      </div>

      <h3 class="font-bold text-text-primary text-2xl md:text-3xl lg:text-4xl leading-tight group-hover:text-accent transition-colors duration-200">
        {title}
      </h3>

      <p class="text-text-secondary text-base leading-relaxed line-clamp-3">
        {description}
      </p>

      <div class="flex items-center gap-1.5 text-sm text-text-muted pt-1">
        <span>{author.id.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</span>
        <span aria-hidden="true">&middot;</span>
        <time datetime={publishedAt.toISOString()}>
          {formatDate(publishedAt)}
        </time>
        {readingTime && (
          <>
            <span aria-hidden="true">&middot;</span>
            <span>{readingTime}</span>
          </>
        )}
      </div>
    </div>
  </div>
</a>
