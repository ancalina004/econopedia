---
import { Image } from 'astro:assets';
import CategoryBadge from './CategoryBadge.astro';
import { formatDateShort } from '../../lib/utils';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      cover: ImageMetadata | string;
      coverAlt: string;
      coverIsUrl?: boolean;
      categories: string[];
      publishedAt: Date;
    };
  };
  readingTime?: string;
  loading?: 'eager' | 'lazy';
}

const { post, readingTime, loading = 'lazy' } = Astro.props;
const { title, cover, coverAlt, coverIsUrl, categories, publishedAt } = post.data;
---

<a
  href={`/blog/${post.slug}`}
  class="group flex gap-3 py-2.5"
>
  <!-- Text content: left-aligned, minimal -->
  <div class="flex-1 min-w-0 flex flex-col justify-center">
    {categories[0] && <CategoryBadge category={categories[0]} size="sm" />}

    <h3 class="text-base font-semibold leading-snug text-text-primary mt-1 line-clamp-2 group-hover:text-accent transition-colors duration-200">
      {title}
    </h3>

    <div class="flex items-center gap-1.5 text-xs text-text-muted mt-1">
      <time datetime={publishedAt.toISOString()}>
        {formatDateShort(publishedAt)}
      </time>
      {readingTime && (
        <>
          <span aria-hidden="true">&middot;</span>
          <span>{readingTime}</span>
        </>
      )}
    </div>
  </div>

  <!-- Thumbnail: landscape ratio, editorial feel -->
  <div class="w-24 h-16 flex-shrink-0 overflow-hidden">
    {coverIsUrl ? (
      <Image
        src={cover as string}
        alt={coverAlt}
        width={192}
        height={128}
        loading={loading}
        class="w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-300"
      />
    ) : (
      <Image
        src={cover as ImageMetadata}
        alt={coverAlt}
        loading={loading}
        widths={[128, 256]}
        sizes="96px"
        class="w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-300"
      />
    )}
  </div>
</a>
