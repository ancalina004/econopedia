---
import { Image } from 'astro:assets';
import CategoryBadge from './CategoryBadge.astro';
import { formatDate } from '../../lib/utils';

interface Props {
  title: string;
  description: string;
  categories: string[];
  publishedAt: Date;
  updatedAt?: Date;
  author: {
    name: string;
    avatar?: ImageMetadata;
    role: string;
  };
  readingTime: string;
  cover?: ImageMetadata | string;
  coverAlt: string;
  coverIsUrl?: boolean;
}

const {
  title,
  description,
  categories,
  publishedAt,
  updatedAt,
  author,
  readingTime,
  cover,
  coverAlt,
  coverIsUrl,
} = Astro.props;
---

<header>
  <!-- Text block — left-aligned, centered column -->
  <div class="max-w-4xl mx-auto">
    <!-- Categories -->
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
      {categories.map((cat, i) => (
        <>
          {i > 0 && <span class="text-text-muted text-xs select-none" aria-hidden="true">/</span>}
          <CategoryBadge category={cat} size="md" />
        </>
      ))}
    </div>

    <!-- Title -->
    <h1 class="mt-3 text-4xl lg:text-5xl font-semibold text-text-primary leading-tight">
      {title}
    </h1>

    <!-- Description -->
    <p class="mt-3 text-lg text-text-secondary leading-relaxed">
      {description}
    </p>

    <!-- Byline -->
    <div class="mt-6 flex items-center gap-3">
      {author.avatar ? (
        <Image
          src={author.avatar}
          alt={author.name}
          width={40}
          height={40}
          loading="eager"
          class="w-10 h-10 rounded-full object-cover"
        />
      ) : (
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center text-accent font-semibold text-sm">
          {author.name.charAt(0)}
        </div>
      )}
      <div class="flex flex-col items-start text-sm">
        <div class="flex items-center gap-x-1.5">
          <span class="font-semibold text-text-primary">{author.name}</span>
          {author.role && (
            <span class="text-text-muted">&mdash; {author.role}</span>
          )}
        </div>
        <div class="flex items-center gap-x-1.5 text-text-muted">
          <time datetime={publishedAt.toISOString()}>
            {formatDate(publishedAt)}
          </time>
          {updatedAt && (
            <>
              <span aria-hidden="true">&middot;</span>
              <span>
                Updated <time datetime={updatedAt.toISOString()}>{formatDate(updatedAt)}</time>
              </span>
            </>
          )}
          <span aria-hidden="true">&middot;</span>
          <span>{readingTime}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Cover image — matches header width -->
  {cover && (
    <div class="mt-8 overflow-hidden max-w-4xl mx-auto">
      {coverIsUrl ? (
        <Image
          src={cover as string}
          alt={coverAlt}
          width={1200}
          height={600}
          loading="eager"
          class="w-full aspect-[2/1] object-cover"
        />
      ) : (
        <Image
          src={cover as ImageMetadata}
          alt={coverAlt}
          loading="eager"
          widths={[600, 900, 1200]}
          sizes="(max-width: 768px) 100vw, 672px"
          class="w-full aspect-[2/1] object-cover"
        />
      )}
    </div>
  )}
</header>
