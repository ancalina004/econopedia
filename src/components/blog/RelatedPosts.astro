---
import PostCard from './PostCard.astro';

interface Props {
  posts: {
    slug: string;
    data: {
      title: string;
      description: string;
      cover: ImageMetadata;
      coverAlt: string;
      categories: string[];
      publishedAt: Date;
      author: { id: string };
    };
  }[];
}

const { posts } = Astro.props;

if (posts.length === 0) return;
---

<section class="space-y-6">
  <h2 class="text-2xl font-semibold text-text-primary">
    You might also like
  </h2>

  <div
    class:list={[
      'grid gap-6',
      posts.length === 1 && 'grid-cols-1 max-w-md',
      posts.length === 2 && 'grid-cols-1 sm:grid-cols-2',
      posts.length >= 3 && 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
    ]}
  >
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </div>
</section>
