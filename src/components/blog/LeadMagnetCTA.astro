---
import LeadMagnetGate from './LeadMagnetGate';

interface Props {
  title: string;
  description: string;
  file: string;
  gated?: boolean;
}

const { title, description, file, gated = false } = Astro.props;
---

{gated ? (
  <LeadMagnetGate
    title={title}
    description={description}
    file={file}
    client:visible
  />
) : (
  <div class="my-10 border-t-2 border-accent" style="background: var(--color-surface);">
    <div class="px-8 py-8 flex flex-col sm:flex-row items-start gap-6">
      <!-- Icon -->
      <div class="flex-shrink-0 w-14 h-14 flex items-center justify-center border border-border">
        <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m.75 12 3 3m0 0 3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z" />
        </svg>
      </div>

      <!-- Content -->
      <div class="flex-1">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-accent mb-2">Free Resource</p>
        <h3 class="font-semibold text-text-primary text-lg leading-snug">{title}</h3>
        <p class="text-text-secondary text-sm leading-relaxed mt-1.5 max-w-lg">{description}</p>
        <a
          href={file}
          download
          class="inline-flex items-center gap-2 mt-4 px-5 py-2.5 bg-accent hover:bg-accent-hover text-white text-[13px] font-semibold tracking-wide transition-colors duration-150"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Download PDF
        </a>
      </div>
    </div>
  </div>
)}
